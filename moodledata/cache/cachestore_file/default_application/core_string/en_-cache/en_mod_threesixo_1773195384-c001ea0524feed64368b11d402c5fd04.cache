:"Release after the activity has closed";s:10:"rel_closed";s:22:"Closed to participants";s:10:"rel_manual";s:14:"Manual release";s:8:"rel_open";s:20:"Open to participants";s:7:"release";s:31:"Release reports to participants";s:13:"release_close";s:29:"Close reports to participants";s:9:"releasing";s:9:"Releasing";s:14:"releasing_help";s:703:"Whether to let the participants view the report of the feedback given to them.
<ul>
<li>Closed to participants. Participants cannot view their own feedback report. Only those with the capability to manage the 360-degree feedback activity (e.g. teacher, manager, admin) can view the participants' feedback reports.</li>
<li>Open to participants. Participants can view their own feedback report any time.</li>
<li>Manual release. Participants can view their own feedback report when released by a user who has the capability to manage the 360-degree feedback activity.</li>
<li>Release after the activity has closed. Participants can view their own feedback report after the activity has ended.</li>
</ul>";s:9:"responses";s:9:"Responses";s:14:"responsessaved";s:31:"Your responses have been saved.";s:10:"scaleagree";s:5:"Agree";s:13:"scaledisagree";s:8:"Disagree";s:18:"scalenotapplicable";s:14:"Not applicable";s:18:"scalesomewhatagree";s:14:"Somewhat agree";s:21:"scalesomewhatdisagree";s:17:"Somewhat disagree";s:18:"scalestronglyagree";s:14:"Strongly agree";s:21:"scalestronglydisagree";s:17:"Strongly disagree";s:18:"selectparticipants";s:19:"Select participants";s:16:"showownquestions";s:33:"Only show the questions I created";s:6:"status";s:6:"Status";s:15:"statuscompleted";s:9:"Completed";s:14:"statusdeclined";s:8:"Declined";s:16:"statusinprogress";s:11:"In progress";s:13:"statuspending";s:7:"Pending";s:14:"statusviewonly";s:9:"View only";s:11:"submissions";s:11:"Submissions";s:12:"switchtouser";s:17:"Switch to user...";s:21:"threesixo:addinstance";s:33:"Add a new 360° feedback instance";s:22:"threesixo:addquestions";s:35:"Create new 360° feedback questions";s:18:"threesixo:complete";s:25:"Complete a 360° feedback";s:31:"threesixo:deleteothersquestions";s:49:"Delete 360° feedback questions created by others";s:25:"threesixo:deletequestions";s:31:"Delete 360° feedback questions";s:19:"threesixo:edititems";s:25:"Edit 360° feedback items";s:29:"threesixo:editothersquestions";s:47:"Edit 360° feedback questions created by others";s:23:"threesixo:editquestions";s:29:"Edit 360° feedback questions";s:19:"threesixo:mapcourse";s:28:"Map 360° feedback to course";s:21:"threesixo:receivemail";s:28:"Receive 360° feedback email";s:14:"threesixo:view";s:19:"View 360° feedback";s:25:"threesixo:viewanalysepage";s:28:"View 360° feedback analysis";s:21:"threesixo:viewreports";s:27:"View 360° feedback reports";s:5:"title";s:14:"360° feedback";s:16:"titlemanageitems";s:27:"Manage 360° feedback items";s:4:"todo";s:5:"To Do";s:11:"undodecline";s:12:"Undo decline";s:4:"view";s:4:"View";s:19:"viewfeedbackforuser";s:22:"View feedback for user";s:18:"viewfeedbackreport";s:20:"View feedbac