s:2520:".login-form::before {
    content: "";
    display: block;
    width: 100%;
    height: 65px;                        
    background-image: url('https://shofcotest.assetmaster.cloud/pluginfile.php/1/theme_klassroom/logo/1769494662/shofco_logo__169x40.png');
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center center;
    margin: 0 auto 1rem auto; 
}

.login-form::before {
    max-width: 100px;
    margin-left: auto;
    margin-right: auto;
}

/* Make it responsive – smaller on mobile if form stacks */
@media (max-width: 767px) {
    .pagelayout-login .login-form::before {
        height: 60px; 
    }
}

.login-form {  
    background-color: #00B2E3 !important; 
}

col-lg-12.col-md-12.col-sm-12.full,
.pagelayout-frontpage .full a img[src*="projectaddbanner"] {
    display: none !important;
}

/* Hide header/page banner on all pages EXCEPT front page */
body:not(.pagelayout-frontpage) .header-banner,
body:not(.pagelayout-frontpage) .page-header-banner,
body:not(.pagelayout-frontpage) .hero-banner,
body:not(.pagelayout-frontpage) .top-banner,
body:not(.pagelayout-frontpage) .secondary-banner,
body:not(.pagelayout-frontpage) [class*="banner"],
body:not(.pagelayout-frontpage) .header-image,
body:not(.pagelayout-frontpage) .page-header-image {
    display: none !important;
}

body.pagelayout-login button.btn.btn-secondary[data-modal="alert"][data-modal-title-str*="cookiesenabled"] {
    display: none !important;
}

body.pagelayout-frontpage #allcourses {
    display: none !important;
}

body.pagelayout-frontpage #news {
    display: none !important;
}

.welcome-image img {
    content: url('https://shofcotest.assetmaster.cloud/pluginfile.php/1/theme_klassroom/classroomimage1/1770292480/shofco_lms_.png') !important;
    width: 100% !important;
    height: auto !important;
    object-fit: cover !important;    // keeps proportions, fills space nicely
}

body.pagelayout-frontpage #page-content {
    display: none !important;
}

